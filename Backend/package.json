{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "nodemon src/server.js",
    "dev": "nodemon --watch src/server.js",
    "migrate:jamdani": "node scripts/migrate-panjabi-images.js",
    "migrate:dupatta:images": "node scripts/import-dupatta-images.js",
    "migrate:vases:products": "node scripts/import-vases-products.js",
    "migrate:plates-platters:products": "node scripts/import-plates-platters-products.js",
    "scrape:plates-platters:listing": "node scripts/scrape-plates-platters-listing.js",
    "scrape:wall-hangings:listing": "node scripts/scrape-wall-hangings-listing.js",
    "migrate:wall-hangings:products": "node scripts/import-wall-hangings-products.js",
    "migrate:wall-hangings:images": "node scripts/import-wall-hangings-images.js",
    "verify:wall-hangings": "node -e \"const{Pool}=require('pg');require('dotenv').config({path:'.env'});const p=new Pool({host:process.env.DB_HOST,port:process.env.DB_PORT,database:process.env.DB_NAME,user:process.env.DB_USER,password:process.env.DB_PASSWORD});p.query(\\\"SELECT COUNT(*)::int AS products,(SELECT COUNT(*)::int FROM product_image pi JOIN product_variant pv ON pv.variant_id=pi.variant_id JOIN product pr ON pr.product_id=pv.product_id JOIN category c2 ON c2.category_id=pr.category_id WHERE LOWER(c2.name)='wall hangings') AS images FROM product p JOIN category c ON c.category_id=p.category_id WHERE LOWER(c.name)='wall hangings'\\\").then(r=>console.log('Wall Hangings:',r.rows[0])).finally(()=>p.end())\"",
    "db:sync:vases:details": "node scripts/sync-vases-details-and-dedupe.js",
    "db:sync:plates-platters:details": "node scripts/sync-plates-platters-details-and-dedupe.js",
    "migrate:vases:images": "node scripts/import-vases-images.js",
    "migrate:vases:fallback-images": "node scripts/fill-vases-fallback-images.js",
    "restore:terracotta:clay": "node scripts/restore-terracotta-clay-from-cloudinary.js",
    "db:consolidate:terracotta-clay": "node scripts/consolidate-terracotta-clay.js",
    "db:merge:terracotta-clay-single": "node scripts/merge-terracotta-clay-single-category.js",
    "db:finalize:home-decor-terracotta-clay": "node scripts/finalize-home-decor-terracotta-clay.js",
    "db:normalize:home-decor-parent": "node scripts/normalize-home-decor-parent.js",
    "db:merge:home-decor-duplicates": "node scripts/merge-home-decor-duplicate-children.js",
    "verify:vases": "node scripts/verify-vases.js",
    "verify:plates-platters": "node scripts/verify-plates-platters.js",
    "verify:vases:images": "node scripts/verify-vases-images.js",
    "verify:terracotta:clay": "node scripts/verify-terracotta-clay.js",
    "migrate:skill": "node scripts/run-migration-skill.js",
    "cloudinary:folders:bd": "node scripts/setup-cloudinary-folders.js",
    "cloudinary:move:jamdani": "node scripts/move-jamdani-assets.js",
    "cloudinary:move:muslin": "node scripts/move-muslin-assets.js",
    "sync:jamdani:paths": "node scripts/sync-jamdani-paths.js",
    "db:normalize:women-categories": "node scripts/normalize-women-categories.js",
    "db:schema": "psql -U postgres -d folkmint -f src/schema/FolkMint.session.sql",
    "db:seed": "node src/schema/runSeed.js",
    "db:reset": "npm run db:schema && npm run db:seed",
    "db:test": "node src/test.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "\\",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemon": "^3.1.11",
    "pg": "^8.17.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "playwright": "^1.53.0"
  }
}
